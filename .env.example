# 🎯 Mentoria Hub - Main Environment Variables
# Copy this file to .env and update values as needed

# Project
PROJECT_NAME=Mentoria Hub
ENVIRONMENT=development
DEBUG=true

# Backend
BACKEND_URL=http://localhost:8000
BACKEND_PORT=8000

# Frontend
FRONTEND_URL=http://localhost:5173
FRONTEND_PORT=5173

# Database
DATABASE_URL=sqlite:///./backend/mentoria.db

# Telegram
TELEGRAM_CHANNEL=mentoria_updates

# Version
VERSION=1.0.0
